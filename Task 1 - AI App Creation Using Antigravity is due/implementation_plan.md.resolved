│   ├── vendor/page.tsx             # Vendor dashboard
│   ├── otp/[id]/page.tsx           # OTP verification & escrow release
│   ├── feedback/[id]/page.tsx      # Feedback & rating
│   └── layout.tsx                  # Root layout
├── components/
│   ├── TrainTracker.tsx            # NTES API status + distance widget
│   ├── LiveMap.tsx                 # Leaflet map with agent marker
│   ├── FoodCard.tsx                # Menu item card
│   ├── CartDrawer.tsx              # Slide-out cart
│   ├── EscrowStatus.tsx            # Escrow progress UI
│   ├── OTPInput.tsx               # OTP entry component
│   └── Notification.tsx           # Toast notifications
├── lib/
│   ├── mockDb.ts                   # In-memory mock database
│   ├── mockNTES.ts                 # Mock NTES train tracking
│   ├── mockEscrow.ts              # Mock escrow logic
│   ├── aiRecommendations.ts        # AI food recommendation logic
│   └── types.ts                    # TypeScript types
├── api/
│   ├── train/route.ts              # NTES proxy / mock endpoint
│   ├── orders/route.ts             # Order CRUD
│   ├── vendor/notify/route.ts      # Vendor notification trigger
